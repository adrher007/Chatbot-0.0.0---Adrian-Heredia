        "def llamar_modelo(mensaje, temperatura=0.7, max_tokens=200):\n",
        "    payload = {\n",
        "        \"inputs\": mensaje,\n",
        "        \"parameters\": {\n",
        "            \"temperature\":   temperatura,\n",
        "            \"max_new_tokens\": max_tokens,\n",
        "            \"return_full_text\": False\n",
        "        }\n",
        "    }\n",
        "    respuesta = requests.post(API_URL, headers=HEADERS, json=payload)\n",
        "    if respuesta.status_code == 200:\n",
        "        return respuesta.json()[0][\"generated_text\"].strip()\n",
        "    else:\n",
        "        return f\"Error {respuesta.status_code}: {respuesta.text}\"\n",
        "\n",
        "respuesta = llamar_modelo(\"¿Qué es la inteligencia artificial en una frase?\")\n",
        "print(\"Respuesta del modelo:\")\n",
        "print(respuesta)"
